{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "lulang",
  "scopeName": "source.lulang",
  "patterns": [
    {"include": "#comments"},
    {"include": "#strings"},
    {"include": "#numbers"},
    {"include": "#declarations"},
    {"include": "#keywords"},
    {"include": "#types"},
    {"include": "#operators"}
  ],
  "repository": {
    "comments": {
      "patterns": [{"name": "comment.line.double-slash.lulang", "match": "//.*$"}]
    },
    "strings": {
      "patterns": [{
        "name": "string.quoted.double.lulang",
        "begin": "\"",
        "end": "\"",
        "patterns": [{"name": "constant.character.escape.lulang", "match": "\\\\."}]
      }, {
        "name": "string.quoted.single.lulang",
        "begin": "'",
        "end": "'",
        "patterns": [{"name": "constant.character.escape.lulang", "match": "\\\\."}]
      }]
    },
    "numbers": {
      "patterns": [{"name": "constant.numeric.lulang", "match": "\\b(?:\\d+(?:\\.\\d*)?|\\.\\d+)(?:[eE][+-]?\\d+)?\\b"}]
    },
    "declarations": {
      "patterns": [{
        "match": "\\b(fn|type|enum|property)\\s+([A-Za-z_][A-Za-z0-9_]*)",
        "captures": {
          "1": {"name": "storage.type.lulang"},
          "2": {"name": "entity.name.function.lulang"}
        }
      }]
    },
    "keywords": {
      "patterns": [{"name": "keyword.control.lulang", "match": "\\b(?:main|fn|export|extern|type|enum|property|operator|let|var|inout|return|if|else|for|in|while|and|or|not)\\b"}]
    },
    "types": {
      "patterns": [{"name": "storage.type.builtin.lulang", "match": "\\b(?:i32|i64|f32|f64|bool|str|c_ptr|c_slice)\\b|\\(\\)"}]
    },
    "operators": {
      "patterns": [{"name": "keyword.operator.lulang", "match": "(?:==|!=|~=|<=|>=|\\.\\.|[-+*/%=<>])"}]
    }
  }
}
