}
fn link_preview_options_get_is_disabled(value: LinkPreviewOptions): bool {
  return json_bool(json_get(value.json, "is_disabled"))
}

// Optional. URL to use for the link preview. If empty, then the first URL found in the message text will be used.
fn link_preview_options_has_url(value: LinkPreviewOptions): bool {
  return json_has(value.json, "url")
}
fn link_preview_options_get_url(value: LinkPreviewOptions): str {
  return json_string(json_get(value.json, "url"))
}

// Optional. True, if the media in the link preview is supposed to be shrunk; ignored if the URL isn't explicitly specified or media size change isn't supported for the preview
fn link_preview_options_has_prefer_small_media(value: LinkPreviewOptions): bool {
  return json_has(value.json, "prefer_small_media")
}
fn link_preview_options_get_prefer_small_media(value: LinkPreviewOptions): bool {
  return json_bool(json_get(value.json, "prefer_small_media"))
}

// Optional. True, if the media in the link preview is supposed to be enlarged; ignored if the URL isn't explicitly specified or media size change isn't supported for the preview
fn link_preview_options_has_prefer_large_media(value: LinkPreviewOptions): bool {
  return json_has(value.json, "prefer_large_media")
}
fn link_preview_options_get_prefer_large_media(value: LinkPreviewOptions): bool {
  return json_bool(json_get(value.json, "prefer_large_media"))
}

// Optional. True, if the link preview must be shown above the message text; otherwise, the link preview will be shown below the message text
fn link_preview_options_has_show_above_text(value: LinkPreviewOptions): bool {
  return json_has(value.json, "show_above_text")
}
fn link_preview_options_get_show_above_text(value: LinkPreviewOptions): bool {
  return json_bool(json_get(value.json, "show_above_text"))
}

// Currency in which the post will be paid. Currently, must be one of “XTR” for Telegram Stars or “TON” for TON grams.
fn suggested_post_price_has_currency(value: SuggestedPostPrice): bool {
  return json_has(value.json, "currency")
}
fn suggested_post_price_get_currency(value: SuggestedPostPrice): str {
  return json_string(json_get(value.json, "currency"))
}

// The amount of the currency that will be paid for the post in the smallest units of the currency, i.e. Telegram Stars or nanograms. Currently, price in Telegram Stars must be between 5 and 100000, and price in nanograms must be between 10000000 and 10000000000000.
fn suggested_post_price_has_amount(value: SuggestedPostPrice): bool {
  return json_has(value.json, "amount")
}
fn suggested_post_price_get_amount(value: SuggestedPostPrice): i64 {
  return json_i64(json_get(value.json, "amount"))
}

// State of the suggested post. Currently, it can be one of “pending”, “approved”, “declined”.
fn suggested_post_info_has_state(value: SuggestedPostInfo): bool {
  return json_has(value.json, "state")
}
fn suggested_post_info_get_state(value: SuggestedPostInfo): str {
  return json_string(json_get(value.json, "state"))
}

// Optional. Proposed price of the post. If the field is omitted, then the post is unpaid.
fn suggested_post_info_has_price(value: SuggestedPostInfo): bool {
  return json_has(value.json, "price")
}
fn suggested_post_info_get_price(value: SuggestedPostInfo): SuggestedPostPrice {
  return SuggestedPostPrice { json: json_get(value.json, "price") }
}

// Optional. Proposed send date of the post. If the field is omitted, then the post can be published at any time within 30 days at the sole discretion of the user or administrator who approves it.
fn suggested_post_info_has_send_date(value: SuggestedPostInfo): bool {
  return json_has(value.json, "send_date")
}
fn suggested_post_info_get_send_date(value: SuggestedPostInfo): i64 {
  return json_i64(json_get(value.json, "send_date"))
}

// Optional. Proposed price for the post. If the field is omitted, then the post is unpaid.
fn suggested_post_parameters_has_price(value: SuggestedPostParameters): bool {
  return json_has(value.json, "price")
}
fn suggested_post_parameters_get_price(value: SuggestedPostParameters): SuggestedPostPrice {
  return SuggestedPostPrice { json: json_get(value.json, "price") }
}

// Optional. Proposed send date of the post. If specified, then the date must be between 300 second and 2678400 seconds (30 days) in the future. If the field is omitted, then the post can be published at any time within 30 days at the sole discretion of the user who approves it.
fn suggested_post_parameters_has_send_date(value: SuggestedPostParameters): bool {
  return json_has(value.json, "send_date")
}
fn suggested_post_parameters_get_send_date(value: SuggestedPostParameters): i64 {
  return json_i64(json_get(value.json, "send_date"))
}

// Unique identifier of the topic. This number may have more than 32 significant bits and some programming languages may have difficulty/silent defects in interpreting it. But it has at most 52 significant bits, so a 64-bit integer or double-precision float type are safe for storing this identifier.
fn direct_messages_topic_has_topic_id(value: DirectMessagesTopic): bool {
  return json_has(value.json, "topic_id")
}
fn direct_messages_topic_get_topic_id(value: DirectMessagesTopic): i64 {
  return json_i64(json_get(value.json, "topic_id"))
}

