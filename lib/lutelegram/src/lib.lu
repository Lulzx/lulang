          if depth == 0 { return i + 1 }
        }
        i = i + 1
      }
    }
    return len(source)
  }
  var i = first
  while i < len(source) and source[i] != 44 and source[i] != 125 and source[i] != 93 {
    i = i + 1
  }
  while i > first and json_space(source[i - 1]) { i = i - 1 }
  return i
}

fn json_has(source: str, wanted: str): bool {
  return len(json_get(source, wanted)) > 0
