}
fn passport_file_get_file_size(value: PassportFile): i64 {
  return json_i64(json_get(value.json, "file_size"))
}

// Unix time when the file was uploaded
fn passport_file_has_file_date(value: PassportFile): bool {
  return json_has(value.json, "file_date")
}
fn passport_file_get_file_date(value: PassportFile): i64 {
  return json_i64(json_get(value.json, "file_date"))
}

// Element type. One of “personal_details”, “passport”, “driver_license”, “identity_card”, “internal_passport”, “address”, “utility_bill”, “bank_statement”, “rental_agreement”, “passport_registration”, “temporary_registration”, “phone_number”, “email”.
fn encrypted_passport_element_has_type(value: EncryptedPassportElement): bool {
  return json_has(value.json, "type")
}
fn encrypted_passport_element_get_type(value: EncryptedPassportElement): str {
  return json_string(json_get(value.json, "type"))
}

// Optional. Base64-encoded encrypted Telegram Passport element data provided by the user; available only for “personal_details”, “passport”, “driver_license”, “identity_card”, “internal_passport” and “address” types. Can be decrypted and verified using the accompanying EncryptedCredentials.
fn encrypted_passport_element_has_data(value: EncryptedPassportElement): bool {
  return json_has(value.json, "data")
}
fn encrypted_passport_element_get_data(value: EncryptedPassportElement): str {
  return json_string(json_get(value.json, "data"))
}

// Optional. User's verified phone number; available only for “phone_number” type
fn encrypted_passport_element_has_phone_number(value: EncryptedPassportElement): bool {
  return json_has(value.json, "phone_number")
}
fn encrypted_passport_element_get_phone_number(value: EncryptedPassportElement): str {
  return json_string(json_get(value.json, "phone_number"))
}

// Optional. User's verified email address; available only for “email” type
fn encrypted_passport_element_has_email(value: EncryptedPassportElement): bool {
  return json_has(value.json, "email")
}
fn encrypted_passport_element_get_email(value: EncryptedPassportElement): str {
  return json_string(json_get(value.json, "email"))
}

// Optional. Array of encrypted files with documents provided by the user; available only for “utility_bill”, “bank_statement”, “rental_agreement”, “passport_registration” and “temporary_registration” types. Files can be decrypted and verified using the accompanying EncryptedCredentials.
fn encrypted_passport_element_has_files(value: EncryptedPassportElement): bool {
  return json_has(value.json, "files")
}
fn encrypted_passport_element_get_files(value: EncryptedPassportElement): str {
  return json_get(value.json, "files")
}

// Optional. Encrypted file with the front side of the document, provided by the user; available only for “passport”, “driver_license”, “identity_card” and “internal_passport”. The file can be decrypted and verified using the accompanying EncryptedCredentials.
fn encrypted_passport_element_has_front_side(value: EncryptedPassportElement): bool {
  return json_has(value.json, "front_side")
}
fn encrypted_passport_element_get_front_side(value: EncryptedPassportElement): PassportFile {
  return PassportFile { json: json_get(value.json, "front_side") }
}

// Optional. Encrypted file with the reverse side of the document, provided by the user; available only for “driver_license” and “identity_card”. The file can be decrypted and verified using the accompanying EncryptedCredentials.
fn encrypted_passport_element_has_reverse_side(value: EncryptedPassportElement): bool {
  return json_has(value.json, "reverse_side")
}
fn encrypted_passport_element_get_reverse_side(value: EncryptedPassportElement): PassportFile {
  return PassportFile { json: json_get(value.json, "reverse_side") }
}

// Optional. Encrypted file with the selfie of the user holding a document, provided by the user; available if requested for “passport”, “driver_license”, “identity_card” and “internal_passport”. The file can be decrypted and verified using the accompanying EncryptedCredentials.
fn encrypted_passport_element_has_selfie(value: EncryptedPassportElement): bool {
  return json_has(value.json, "selfie")
}
fn encrypted_passport_element_get_selfie(value: EncryptedPassportElement): PassportFile {
  return PassportFile { json: json_get(value.json, "selfie") }
}

// Optional. Array of encrypted files with translated versions of documents provided by the user; available if requested for “passport”, “driver_license”, “identity_card”, “internal_passport”, “utility_bill”, “bank_statement”, “rental_agreement”, “passport_registration” and “temporary_registration” types. Files can be decrypted and verified using the accompanying EncryptedCredentials.
fn encrypted_passport_element_has_translation(value: EncryptedPassportElement): bool {
  return json_has(value.json, "translation")
}
fn encrypted_passport_element_get_translation(value: EncryptedPassportElement): str {
  return json_get(value.json, "translation")
}

// Base64-encoded element hash for using in PassportElementErrorUnspecified
fn encrypted_passport_element_has_hash(value: EncryptedPassportElement): bool {
  return json_has(value.json, "hash")
}
fn encrypted_passport_element_get_hash(value: EncryptedPassportElement): str {
  return json_string(json_get(value.json, "hash"))
}

// Base64-encoded encrypted JSON-serialized data with unique user's payload, data hashes and secrets required for EncryptedPassportElement decryption and authentication
fn encrypted_credentials_has_data(value: EncryptedCredentials): bool {
  return json_has(value.json, "data")
}
fn encrypted_credentials_get_data(value: EncryptedCredentials): str {
  return json_string(json_get(value.json, "data"))
}

// Base64-encoded data hash for data authentication
fn encrypted_credentials_has_hash(value: EncryptedCredentials): bool {
  return json_has(value.json, "hash")
}
fn encrypted_credentials_get_hash(value: EncryptedCredentials): str {
  return json_string(json_get(value.json, "hash"))
}

// Base64-encoded secret, encrypted with the bot's public RSA key, required for data decryption
fn encrypted_credentials_has_secret(value: EncryptedCredentials): bool {
  return json_has(value.json, "secret")
}
fn encrypted_credentials_get_secret(value: EncryptedCredentials): str {
  return json_string(json_get(value.json, "secret"))
}

