  if not first { body = concat(body, ",") }
  body = concat(body, "\"user_id\":")
  body = concat(body, json_from_i64(params.user_id))
  first = false
  if not first { body = concat(body, ",") }
  body = concat(body, "\"score\":")
  body = concat(body, json_from_i64(params.score))
  first = false
  if len(params.optional) > 2 {
    if not first { body = concat(body, ",") }
    body = concat(body, substr(params.optional, 1, len(params.optional) - 1))
  }
  return concat(body, "}")
}

fn set_game_score(token: str, params: SetGameScoreParams): SetGameScoreResponse {
  let envelope = json_request("setGameScore", set_game_score_params_json(params))
  let raw = lutelegram_request(token, envelope)
  let ok = json_bool(json_get(raw, "ok"))
  let error = TelegramError { error_code: json_i64(json_get(raw, "error_code")), description: json_string(json_get(raw, "description")) }
  let result = Message { json: json_get(raw, "result") }
  return SetGameScoreResponse { ok: ok, error: error, result: result, raw: raw }
}

// Use this method to get data for high score tables. Will return the score of the specified user and several of their neighbors in a game. Returns an Array of GameHighScore objects.
type GetGameHighScoresParams {
  // Target user id
  user_id: i64,
  // JSON object containing any optional parameters.
  optional: str,
}

type GetGameHighScoresResponse {
  ok: bool,
  error: TelegramError,
  result: str,
  raw: str,
}

fn get_game_high_scores_params_json(params: GetGameHighScoresParams): str {
  var body = "{"
  var first = true
  if not first { body = concat(body, ",") }
  body = concat(body, "\"user_id\":")
  body = concat(body, json_from_i64(params.user_id))
  first = false
  if len(params.optional) > 2 {
    if not first { body = concat(body, ",") }
    body = concat(body, substr(params.optional, 1, len(params.optional) - 1))
  }
  return concat(body, "}")
}

fn get_game_high_scores(token: str, params: GetGameHighScoresParams): GetGameHighScoresResponse {
  let envelope = json_request("getGameHighScores", get_game_high_scores_params_json(params))
  let raw = lutelegram_request(token, envelope)
  let ok = json_bool(json_get(raw, "ok"))
  let error = TelegramError { error_code: json_i64(json_get(raw, "error_code")), description: json_string(json_get(raw, "description")) }
  let result = json_get(raw, "result")
  return GetGameHighScoresResponse { ok: ok, error: error, result: result, raw: raw }
}
