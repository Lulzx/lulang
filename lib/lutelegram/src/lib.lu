// Identifier for this file, which can be used to download or reuse the file
fn file_has_file_id(value: File): bool {
  return json_has(value.json, "file_id")
}
fn file_get_file_id(value: File): str {
  return json_string(json_get(value.json, "file_id"))
}

// Unique identifier for this file, which is supposed to be the same over time and for different bots. Can't be used to download or reuse the file.
fn file_has_file_unique_id(value: File): bool {
  return json_has(value.json, "file_unique_id")
}
fn file_get_file_unique_id(value: File): str {
  return json_string(json_get(value.json, "file_unique_id"))
}

// Optional. File size in bytes. It can be bigger than 2^31 and some programming languages may have difficulty/silent defects in interpreting it. But it has at most 52 significant bits, so a signed 64-bit integer or double-precision float type are safe for storing this value.
fn file_has_file_size(value: File): bool {
  return json_has(value.json, "file_size")
}
fn file_get_file_size(value: File): i64 {
  return json_i64(json_get(value.json, "file_size"))
}

// Optional. File path. Use https://api.telegram.org/file/bot<token>/<file_path> to get the file.
fn file_has_file_path(value: File): bool {
  return json_has(value.json, "file_path")
}
fn file_get_file_path(value: File): str {
  return json_string(json_get(value.json, "file_path"))
}

