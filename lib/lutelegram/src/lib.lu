fn poll_has_open_period(value: Poll): bool {
  return json_has(value.json, "open_period")
}
fn poll_get_open_period(value: Poll): i64 {
  return json_i64(json_get(value.json, "open_period"))
}

// Optional. Point in time (Unix timestamp) when the poll will be automatically closed
fn poll_has_close_date(value: Poll): bool {
  return json_has(value.json, "close_date")
}
fn poll_get_close_date(value: Poll): i64 {
  return json_i64(json_get(value.json, "close_date"))
}

// Optional. Description of the poll; for polls inside the Message object only
fn poll_has_description(value: Poll): bool {
  return json_has(value.json, "description")
}
fn poll_get_description(value: Poll): str {
  return json_string(json_get(value.json, "description"))
}

