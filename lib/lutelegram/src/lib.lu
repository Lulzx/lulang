fn poll_answer_has_user(value: PollAnswer): bool {
  return json_has(value.json, "user")
}
fn poll_answer_get_user(value: PollAnswer): User {
  return User { json: json_get(value.json, "user") }
}

// 0-based identifiers of chosen answer options. May be empty if the vote was retracted.
fn poll_answer_has_option_ids(value: PollAnswer): bool {
  return json_has(value.json, "option_ids")
}
fn poll_answer_get_option_ids(value: PollAnswer): str {
  return json_get(value.json, "option_ids")
}

// Persistent identifiers of the chosen answer options. May be empty if the vote was retracted.
fn poll_answer_has_option_persistent_ids(value: PollAnswer): bool {
  return json_has(value.json, "option_persistent_ids")
}
fn poll_answer_get_option_persistent_ids(value: PollAnswer): str {
  return json_get(value.json, "option_persistent_ids")
}

// Unique poll identifier
fn poll_has_id(value: Poll): bool {
  return json_has(value.json, "id")
}
fn poll_get_id(value: Poll): str {
  return json_string(json_get(value.json, "id"))
}

// Poll question, 1-300 characters
fn poll_has_question(value: Poll): bool {
  return json_has(value.json, "question")
}
fn poll_get_question(value: Poll): str {
  return json_string(json_get(value.json, "question"))
}

// Optional. Special entities that appear in the question. Currently, only custom emoji entities are allowed in poll questions
fn poll_has_question_entities(value: Poll): bool {
  return json_has(value.json, "question_entities")
}
fn poll_get_question_entities(value: Poll): str {
  return json_get(value.json, "question_entities")
}

// List of poll options
fn poll_has_options(value: Poll): bool {
  return json_has(value.json, "options")
}
fn poll_get_options(value: Poll): str {
  return json_get(value.json, "options")
}

// Total number of users that voted in the poll
fn poll_has_total_voter_count(value: Poll): bool {
  return json_has(value.json, "total_voter_count")
}
fn poll_get_total_voter_count(value: Poll): i64 {
  return json_i64(json_get(value.json, "total_voter_count"))
}

// True, if the poll is closed
fn poll_has_is_closed(value: Poll): bool {
  return json_has(value.json, "is_closed")
}
fn poll_get_is_closed(value: Poll): bool {
  return json_bool(json_get(value.json, "is_closed"))
}

// True, if the poll is anonymous
fn poll_has_is_anonymous(value: Poll): bool {
  return json_has(value.json, "is_anonymous")
}
fn poll_get_is_anonymous(value: Poll): bool {
  return json_bool(json_get(value.json, "is_anonymous"))
}

// Poll type, currently can be “regular” or “quiz”
fn poll_has_type(value: Poll): bool {
  return json_has(value.json, "type")
}
fn poll_get_type(value: Poll): str {
  return json_string(json_get(value.json, "type"))
}

// True, if the poll allows multiple answers
fn poll_has_allows_multiple_answers(value: Poll): bool {
  return json_has(value.json, "allows_multiple_answers")
}
fn poll_get_allows_multiple_answers(value: Poll): bool {
  return json_bool(json_get(value.json, "allows_multiple_answers"))
}

// True, if the poll allows to change the chosen answer options
fn poll_has_allows_revoting(value: Poll): bool {
  return json_has(value.json, "allows_revoting")
}
fn poll_get_allows_revoting(value: Poll): bool {
  return json_bool(json_get(value.json, "allows_revoting"))
}

// True if voting is limited to users who have been members of the chat where the poll was originally sent for more than 24 hours
fn poll_has_members_only(value: Poll): bool {
  return json_has(value.json, "members_only")
}
fn poll_get_members_only(value: Poll): bool {
  return json_bool(json_get(value.json, "members_only"))
}

// Optional. A list of two-letter ISO 3166-1 alpha-2 country codes indicating the countries from which users can vote in the poll. The country code “FT” is used for users with anonymous numbers. If omitted, then users from any country can participate in the poll.
fn poll_has_country_codes(value: Poll): bool {
  return json_has(value.json, "country_codes")
}
fn poll_get_country_codes(value: Poll): str {
  return json_get(value.json, "country_codes")
}

// Optional. Array of 0-based identifiers of the correct answer options. Available only for polls in quiz mode which are closed or were sent (not forwarded) by the bot or to the private chat with the bot.
fn poll_has_correct_option_ids(value: Poll): bool {
  return json_has(value.json, "correct_option_ids")
}
fn poll_get_correct_option_ids(value: Poll): str {
  return json_get(value.json, "correct_option_ids")
}

// Optional. Text that is shown when a user chooses an incorrect answer or taps on the lamp icon in a quiz-style poll, 0-200 characters
fn poll_has_explanation(value: Poll): bool {
