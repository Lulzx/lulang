// Reason for the refund. Currently, one of “post_deleted” if the post was deleted within 24 hours of being posted or removed from scheduled messages without being posted, or “payment_refunded” if the payer refunded their payment.
fn suggested_post_refunded_has_reason(value: SuggestedPostRefunded): bool {
  return json_has(value.json, "reason")
}
fn suggested_post_refunded_get_reason(value: SuggestedPostRefunded): str {
  return json_string(json_get(value.json, "reason"))
}

