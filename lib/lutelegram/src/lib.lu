  return json_has(value.json, "type")
}
fn transaction_partner_telegram_ads_get_type(value: TransactionPartnerTelegramAds): str {
  return json_string(json_get(value.json, "type"))
}

// Type of the transaction partner, always “telegram_api”
fn transaction_partner_telegram_api_has_type(value: TransactionPartnerTelegramApi): bool {
  return json_has(value.json, "type")
}
fn transaction_partner_telegram_api_get_type(value: TransactionPartnerTelegramApi): str {
  return json_string(json_get(value.json, "type"))
}

// The number of successful requests that exceeded regular limits and were therefore billed
fn transaction_partner_telegram_api_has_request_count(value: TransactionPartnerTelegramApi): bool {
  return json_has(value.json, "request_count")
}
fn transaction_partner_telegram_api_get_request_count(value: TransactionPartnerTelegramApi): i64 {
  return json_i64(json_get(value.json, "request_count"))
}

// Type of the transaction partner, always “other”
fn transaction_partner_other_has_type(value: TransactionPartnerOther): bool {
  return json_has(value.json, "type")
}
fn transaction_partner_other_get_type(value: TransactionPartnerOther): str {
  return json_string(json_get(value.json, "type"))
}

// Unique identifier of the transaction. Coincides with the identifier of the original transaction for refund transactions. Coincides with SuccessfulPayment.telegram_payment_charge_id for successful incoming payments from users.
fn star_transaction_has_id(value: StarTransaction): bool {
  return json_has(value.json, "id")
}
fn star_transaction_get_id(value: StarTransaction): str {
  return json_string(json_get(value.json, "id"))
}

// Integer amount of Telegram Stars transferred by the transaction
fn star_transaction_has_amount(value: StarTransaction): bool {
  return json_has(value.json, "amount")
}
fn star_transaction_get_amount(value: StarTransaction): i64 {
  return json_i64(json_get(value.json, "amount"))
}

// Optional. The number of 1/1000000000 shares of Telegram Stars transferred by the transaction; from 0 to 999999999
fn star_transaction_has_nanostar_amount(value: StarTransaction): bool {
  return json_has(value.json, "nanostar_amount")
}
fn star_transaction_get_nanostar_amount(value: StarTransaction): i64 {
  return json_i64(json_get(value.json, "nanostar_amount"))
}

// Date the transaction was created in Unix time
fn star_transaction_has_date(value: StarTransaction): bool {
  return json_has(value.json, "date")
}
fn star_transaction_get_date(value: StarTransaction): i64 {
  return json_i64(json_get(value.json, "date"))
}

// Optional. Source of an incoming transaction (e.g., a user purchasing goods or services, Fragment refunding a failed withdrawal). Only for incoming transactions.
fn star_transaction_has_source(value: StarTransaction): bool {
  return json_has(value.json, "source")
}
fn star_transaction_get_source(value: StarTransaction): TransactionPartner {
  return TransactionPartner { json: json_get(value.json, "source") }
}

// Optional. Receiver of an outgoing transaction (e.g., a user for a purchase refund, Fragment for a withdrawal). Only for outgoing transactions.
fn star_transaction_has_receiver(value: StarTransaction): bool {
  return json_has(value.json, "receiver")
}
fn star_transaction_get_receiver(value: StarTransaction): TransactionPartner {
  return TransactionPartner { json: json_get(value.json, "receiver") }
}

// The list of transactions
fn star_transactions_has_transactions(value: StarTransactions): bool {
  return json_has(value.json, "transactions")
}
fn star_transactions_get_transactions(value: StarTransactions): str {
  return json_get(value.json, "transactions")
}

// Array with information about documents and other Telegram Passport elements that was shared with the bot
fn passport_data_has_data(value: PassportData): bool {
  return json_has(value.json, "data")
}
fn passport_data_get_data(value: PassportData): str {
  return json_get(value.json, "data")
}

// Encrypted credentials required to decrypt the data
fn passport_data_has_credentials(value: PassportData): bool {
  return json_has(value.json, "credentials")
}
fn passport_data_get_credentials(value: PassportData): EncryptedCredentials {
  return EncryptedCredentials { json: json_get(value.json, "credentials") }
}

// Identifier for this file, which can be used to download or reuse the file
fn passport_file_has_file_id(value: PassportFile): bool {
  return json_has(value.json, "file_id")
}
fn passport_file_get_file_id(value: PassportFile): str {
  return json_string(json_get(value.json, "file_id"))
}

// Unique identifier for this file, which is supposed to be the same over time and for different bots. Can't be used to download or reuse the file.
fn passport_file_has_file_unique_id(value: PassportFile): bool {
  return json_has(value.json, "file_unique_id")
}
fn passport_file_get_file_unique_id(value: PassportFile): str {
  return json_string(json_get(value.json, "file_unique_id"))
}

