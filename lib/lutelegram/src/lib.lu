  json: str,
}

// Describes a transaction with payment for paid broadcasting.
type TransactionPartnerTelegramApi {
  json: str,
}

// Describes a transaction with an unknown source or recipient.
type TransactionPartnerOther {
  json: str,
}

// Describes a Telegram Star transaction. Note that if the buyer initiates a chargeback with the payment provider from whom they acquired Stars (e.g., Apple, Google) following this transaction, the refunded Stars will be deducted from the bot's balance. This is outside of Telegram's control.
type StarTransaction {
  json: str,
}

// Contains a list of Telegram Star transactions.
type StarTransactions {
  json: str,
}

// Describes Telegram Passport data shared with the bot by the user.
type PassportData {
  json: str,
}

// This object represents a file uploaded to Telegram Passport. Currently all Telegram Passport files are in JPEG format when decrypted and don't exceed 10MB.
type PassportFile {
  json: str,
}

// Describes documents or other Telegram Passport elements shared with the bot by the user.
type EncryptedPassportElement {
  json: str,
}

// Describes data required for decrypting and authenticating EncryptedPassportElement. See the Telegram Passport Documentation for a complete description of the data decryption and authentication processes.
type EncryptedCredentials {
  json: str,
}

// Represents an issue in one of the data fields that was provided by the user. The error is considered resolved when the field's value changes.
type PassportElementErrorDataField {
  json: str,
}

// Represents an issue with the front side of a document. The error is considered resolved when the file with the front side of the document changes.
type PassportElementErrorFrontSide {
  json: str,
}

// Represents an issue with the reverse side of a document. The error is considered resolved when the file with reverse side of the document changes.
type PassportElementErrorReverseSide {
  json: str,
}

// Represents an issue with the selfie with a document. The error is considered resolved when the file with the selfie changes.
type PassportElementErrorSelfie {
  json: str,
}

// Represents an issue with a document scan. The error is considered resolved when the file with the document scan changes.
type PassportElementErrorFile {
  json: str,
}

// Represents an issue with a list of scans. The error is considered resolved when the list of files containing the scans changes.
type PassportElementErrorFiles {
  json: str,
}

// Represents an issue with one of the files that constitute the translation of a document. The error is considered resolved when the file changes.
type PassportElementErrorTranslationFile {
  json: str,
}

// Represents an issue with the translated version of a document. The error is considered resolved when a file with the document translation change.
type PassportElementErrorTranslationFiles {
  json: str,
}

// Represents an issue in an unspecified place. The error is considered resolved when new data is added.
type PassportElementErrorUnspecified {
  json: str,
}

// This object represents a game. Use BotFather to create and edit games, their short names will act as unique identifiers.
type Game {
  json: str,
}

// A placeholder, currently holds no information. Use BotFather to set up your game.
type CallbackGame {
  json: str,
}

// This object represents one row of the high scores table for a game.
type GameHighScore {
  json: str,
}

// The update's unique identifier. Update identifiers start from a certain positive number and increase sequentially. This identifier becomes especially handy if you're using webhooks, since it allows you to ignore repeated updates or to restore the correct update sequence, should they get out of order. If there are no new updates for at least a week, then identifier of the next update will be chosen randomly instead of sequentially.
fn update_has_update_id(value: Update): bool {
  return json_has(value.json, "update_id")
}
fn update_get_update_id(value: Update): i64 {
  return json_i64(json_get(value.json, "update_id"))
}

// Optional. New incoming message of any kind - text, photo, sticker, etc.
fn update_has_message(value: Update): bool {
  return json_has(value.json, "message")
}
fn update_get_message(value: Update): Message {
  return Message { json: json_get(value.json, "message") }
}

// Optional. New version of a message that is known to the bot and was edited. This update may at times be triggered by changes to message fields that are either unavailable or not actively used by your bot.
fn update_has_edited_message(value: Update): bool {
  return json_has(value.json, "edited_message")
}
fn update_get_edited_message(value: Update): Message {
  return Message { json: json_get(value.json, "edited_message") }
}

// Optional. New incoming channel post of any kind - text, photo, sticker, etc.
fn update_has_channel_post(value: Update): bool {
  return json_has(value.json, "channel_post")
}
fn update_get_channel_post(value: Update): Message {
  return Message { json: json_get(value.json, "channel_post") }
}

// Optional. New version of a channel post that is known to the bot and was edited. This update may at times be triggered by changes to message fields that are either unavailable or not actively used by your bot.
fn update_has_edited_channel_post(value: Update): bool {
  return json_has(value.json, "edited_channel_post")
}
fn update_get_edited_channel_post(value: Update): Message {
  return Message { json: json_get(value.json, "edited_channel_post") }
}

// Optional. The bot was connected to or disconnected from a business account, or a user edited an existing connection with the bot
fn update_has_business_connection(value: Update): bool {
  return json_has(value.json, "business_connection")
}
fn update_get_business_connection(value: Update): BusinessConnection {
  return BusinessConnection { json: json_get(value.json, "business_connection") }
}

// Optional. New message from a connected business account
fn update_has_business_message(value: Update): bool {
  return json_has(value.json, "business_message")
}
fn update_get_business_message(value: Update): Message {
  return Message { json: json_get(value.json, "business_message") }
}

// Optional. New version of a message from a connected business account
fn update_has_edited_business_message(value: Update): bool {
  return json_has(value.json, "edited_business_message")
}
fn update_get_edited_business_message(value: Update): Message {
  return Message { json: json_get(value.json, "edited_business_message") }
}

// Optional. Messages were deleted from a connected business account
fn update_has_deleted_business_messages(value: Update): bool {
  return json_has(value.json, "deleted_business_messages")
}
fn update_get_deleted_business_messages(value: Update): BusinessMessagesDeleted {
  return BusinessMessagesDeleted { json: json_get(value.json, "deleted_business_messages") }
}

// Optional. New guest message. The bot can use the field Message.guest_query_id and the method answerGuestQuery to send a message in response.
fn update_has_guest_message(value: Update): bool {
  return json_has(value.json, "guest_message")
}
fn update_get_guest_message(value: Update): Message {
  return Message { json: json_get(value.json, "guest_message") }
}

// Optional. A reaction to a message was changed by a user. The bot must be an administrator in the chat and must explicitly specify "message_reaction" in the list of allowed_updates to receive these updates. The update isn't received for reactions set by bots.
fn update_has_message_reaction(value: Update): bool {
  return json_has(value.json, "message_reaction")
}
fn update_get_message_reaction(value: Update): MessageReactionUpdated {
  return MessageReactionUpdated { json: json_get(value.json, "message_reaction") }
}

// Optional. Reactions to a message with anonymous reactions were changed. The bot must be an administrator in the chat and must explicitly specify "message_reaction_count" in the list of allowed_updates to receive these updates. The updates are grouped and can be sent with delay up to a few minutes.
fn update_has_message_reaction_count(value: Update): bool {
  return json_has(value.json, "message_reaction_count")
}
fn update_get_message_reaction_count(value: Update): MessageReactionCountUpdated {
  return MessageReactionCountUpdated { json: json_get(value.json, "message_reaction_count") }
}

// Optional. New incoming inline query
fn update_has_inline_query(value: Update): bool {
  return json_has(value.json, "inline_query")
}
fn update_get_inline_query(value: Update): InlineQuery {
  return InlineQuery { json: json_get(value.json, "inline_query") }
}

// Optional. The result of an inline query that was chosen by a user and sent to their chat partner. Please see our documentation on the feedback collecting for details on how to enable these updates for your bot.
fn update_has_chosen_inline_result(value: Update): bool {
  return json_has(value.json, "chosen_inline_result")
}
fn update_get_chosen_inline_result(value: Update): ChosenInlineResult {
  return ChosenInlineResult { json: json_get(value.json, "chosen_inline_result") }
}

// Optional. New incoming callback query
fn update_has_callback_query(value: Update): bool {
  return json_has(value.json, "callback_query")
}
fn update_get_callback_query(value: Update): CallbackQuery {
  return CallbackQuery { json: json_get(value.json, "callback_query") }
}

// Optional. New incoming shipping query. Only for invoices with flexible price.
fn update_has_shipping_query(value: Update): bool {
  return json_has(value.json, "shipping_query")
}
fn update_get_shipping_query(value: Update): ShippingQuery {
  return ShippingQuery { json: json_get(value.json, "shipping_query") }
}

// Optional. New incoming pre-checkout query. Contains full information about checkout.
fn update_has_pre_checkout_query(value: Update): bool {
  return json_has(value.json, "pre_checkout_query")
}
fn update_get_pre_checkout_query(value: Update): PreCheckoutQuery {
  return PreCheckoutQuery { json: json_get(value.json, "pre_checkout_query") }
}

// Optional. A user purchased paid media with a non-empty payload sent by the bot in a non-channel chat
fn update_has_purchased_paid_media(value: Update): bool {
  return json_has(value.json, "purchased_paid_media")
}
fn update_get_purchased_paid_media(value: Update): PaidMediaPurchased {
  return PaidMediaPurchased { json: json_get(value.json, "purchased_paid_media") }
}

// Optional. New poll state. Bots receive only updates about manually stopped polls and polls, which are sent by the bot.
fn update_has_poll(value: Update): bool {
  return json_has(value.json, "poll")
}
fn update_get_poll(value: Update): Poll {
  return Poll { json: json_get(value.json, "poll") }
}

// Optional. A user changed their answer in a non-anonymous poll. Bots receive new votes only in polls that were sent by the bot itself.
fn update_has_poll_answer(value: Update): bool {
  return json_has(value.json, "poll_answer")
}
fn update_get_poll_answer(value: Update): PollAnswer {
  return PollAnswer { json: json_get(value.json, "poll_answer") }
}

// Optional. The bot's chat member status was updated in a chat. For private chats, this update is received only when the bot is blocked or unblocked by the user.
fn update_has_my_chat_member(value: Update): bool {
  return json_has(value.json, "my_chat_member")
}
fn update_get_my_chat_member(value: Update): ChatMemberUpdated {
  return ChatMemberUpdated { json: json_get(value.json, "my_chat_member") }
}

// Optional. A chat member's status was updated in a chat. The bot must be an administrator in the chat and must explicitly specify "chat_member" in the list of allowed_updates to receive these updates.
fn update_has_chat_member(value: Update): bool {
  return json_has(value.json, "chat_member")
}
fn update_get_chat_member(value: Update): ChatMemberUpdated {
  return ChatMemberUpdated { json: json_get(value.json, "chat_member") }
}

// Optional. A request to join the chat has been sent. The bot must have the can_invite_users administrator right in the chat to receive these updates.
fn update_has_chat_join_request(value: Update): bool {
  return json_has(value.json, "chat_join_request")
}
fn update_get_chat_join_request(value: Update): ChatJoinRequest {
  return ChatJoinRequest { json: json_get(value.json, "chat_join_request") }
}

// Optional. A chat boost was added or changed. The bot must be an administrator in the chat to receive these updates.
fn update_has_chat_boost(value: Update): bool {
  return json_has(value.json, "chat_boost")
}
fn update_get_chat_boost(value: Update): ChatBoostUpdated {
  return ChatBoostUpdated { json: json_get(value.json, "chat_boost") }
}

// Optional. A boost was removed from a chat. The bot must be an administrator in the chat to receive these updates.
fn update_has_removed_chat_boost(value: Update): bool {
  return json_has(value.json, "removed_chat_boost")
}
fn update_get_removed_chat_boost(value: Update): ChatBoostRemoved {
  return ChatBoostRemoved { json: json_get(value.json, "removed_chat_boost") }
}

// Optional. A new bot was created to be managed by the bot, or token or owner of a managed bot was changed
fn update_has_managed_bot(value: Update): bool {
  return json_has(value.json, "managed_bot")
}
fn update_get_managed_bot(value: Update): ManagedBotUpdated {
  return ManagedBotUpdated { json: json_get(value.json, "managed_bot") }
}

// Optional. User payment subscription has changed
fn update_has_subscription(value: Update): bool {
  return json_has(value.json, "subscription")
}
fn update_get_subscription(value: Update): BotSubscriptionUpdated {
  return BotSubscriptionUpdated { json: json_get(value.json, "subscription") }
}

// Webhook URL, may be empty if webhook is not set up
fn webhook_info_has_url(value: WebhookInfo): bool {
  return json_has(value.json, "url")
}
fn webhook_info_get_url(value: WebhookInfo): str {
  return json_string(json_get(value.json, "url"))
}

// True, if a custom certificate was provided for webhook certificate checks
fn webhook_info_has_has_custom_certificate(value: WebhookInfo): bool {
  return json_has(value.json, "has_custom_certificate")
}
fn webhook_info_get_has_custom_certificate(value: WebhookInfo): bool {
  return json_bool(json_get(value.json, "has_custom_certificate"))
}

// Number of updates awaiting delivery
fn webhook_info_has_pending_update_count(value: WebhookInfo): bool {
  return json_has(value.json, "pending_update_count")
}
fn webhook_info_get_pending_update_count(value: WebhookInfo): i64 {
  return json_i64(json_get(value.json, "pending_update_count"))
}

// Optional. Currently used webhook IP address
fn webhook_info_has_ip_address(value: WebhookInfo): bool {
  return json_has(value.json, "ip_address")
}
fn webhook_info_get_ip_address(value: WebhookInfo): str {
  return json_string(json_get(value.json, "ip_address"))
}

// Optional. Unix time for the most recent error that happened when trying to deliver an update via webhook
fn webhook_info_has_last_error_date(value: WebhookInfo): bool {
  return json_has(value.json, "last_error_date")
}
fn webhook_info_get_last_error_date(value: WebhookInfo): i64 {
  return json_i64(json_get(value.json, "last_error_date"))
}

// Optional. Error message in human-readable format for the most recent error that happened when trying to deliver an update via webhook
fn webhook_info_has_last_error_message(value: WebhookInfo): bool {
  return json_has(value.json, "last_error_message")
}
fn webhook_info_get_last_error_message(value: WebhookInfo): str {
  return json_string(json_get(value.json, "last_error_message"))
}

// Optional. Unix time of the most recent error that happened when trying to synchronize available updates with Telegram datacenters
fn webhook_info_has_last_synchronization_error_date(value: WebhookInfo): bool {
  return json_has(value.json, "last_synchronization_error_date")
}
fn webhook_info_get_last_synchronization_error_date(value: WebhookInfo): i64 {
  return json_i64(json_get(value.json, "last_synchronization_error_date"))
}

// Optional. The maximum allowed number of simultaneous HTTPS connections to the webhook for update delivery
fn webhook_info_has_max_connections(value: WebhookInfo): bool {
  return json_has(value.json, "max_connections")
}
fn webhook_info_get_max_connections(value: WebhookInfo): i64 {
  return json_i64(json_get(value.json, "max_connections"))
}

// Optional. A list of update types the bot is subscribed to. Defaults to all update types except chat_member, message_reaction, and message_reaction_count.
fn webhook_info_has_allowed_updates(value: WebhookInfo): bool {
  return json_has(value.json, "allowed_updates")
}
fn webhook_info_get_allowed_updates(value: WebhookInfo): str {
  return json_get(value.json, "allowed_updates")
}

// Unique identifier for this user or bot. This number may have more than 32 significant bits and some programming languages may have difficulty/silent defects in interpreting it. But it has at most 52 significant bits, so a 64-bit integer or double-precision float type are safe for storing this identifier.
fn user_has_id(value: User): bool {
  return json_has(value.json, "id")
}
fn user_get_id(value: User): i64 {
  return json_i64(json_get(value.json, "id"))
}

// True, if this user is a bot
fn user_has_is_bot(value: User): bool {
  return json_has(value.json, "is_bot")
}
fn user_get_is_bot(value: User): bool {
  return json_bool(json_get(value.json, "is_bot"))
}

// User's or bot's first name
fn user_has_first_name(value: User): bool {
  return json_has(value.json, "first_name")
}
fn user_get_first_name(value: User): str {
  return json_string(json_get(value.json, "first_name"))
}

// Optional. User's or bot's last name
fn user_has_last_name(value: User): bool {
  return json_has(value.json, "last_name")
}
fn user_get_last_name(value: User): str {
  return json_string(json_get(value.json, "last_name"))
}

// Optional. User's or bot's username
fn user_has_username(value: User): bool {
  return json_has(value.json, "username")
}
fn user_get_username(value: User): str {
