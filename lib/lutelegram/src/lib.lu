// Optional. Type of the chat from which the inline query was sent. Can be either “sender” for a private chat with the inline query sender, “private”, “group”, “supergroup”, or “channel”. The chat type should be always known for requests sent from official clients and most third-party clients, unless the request was sent from a secret chat.
fn inline_query_has_chat_type(value: InlineQuery): bool {
  return json_has(value.json, "chat_type")
}
fn inline_query_get_chat_type(value: InlineQuery): str {
  return json_string(json_get(value.json, "chat_type"))
}

// Optional. Sender location, only for bots that request user location
fn inline_query_has_location(value: InlineQuery): bool {
  return json_has(value.json, "location")
}
fn inline_query_get_location(value: InlineQuery): Location {
  return Location { json: json_get(value.json, "location") }
}

