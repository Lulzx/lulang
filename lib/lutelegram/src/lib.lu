fn web_app_info_has_url(value: WebAppInfo): bool {
  return json_has(value.json, "url")
}
fn web_app_info_get_url(value: WebAppInfo): str {
  return json_string(json_get(value.json, "url"))
}

// Array of button rows, each represented by an Array of KeyboardButton objects
fn reply_keyboard_markup_has_keyboard(value: ReplyKeyboardMarkup): bool {
  return json_has(value.json, "keyboard")
}
fn reply_keyboard_markup_get_keyboard(value: ReplyKeyboardMarkup): str {
  return json_get(value.json, "keyboard")
}

// Optional. Requests clients to always show the keyboard when the regular keyboard is hidden. Defaults to False, in which case the custom keyboard can be hidden and opened with a keyboard icon.
fn reply_keyboard_markup_has_is_persistent(value: ReplyKeyboardMarkup): bool {
  return json_has(value.json, "is_persistent")
}
fn reply_keyboard_markup_get_is_persistent(value: ReplyKeyboardMarkup): bool {
  return json_bool(json_get(value.json, "is_persistent"))
}

// Optional. Requests clients to resize the keyboard vertically for optimal fit (e.g., make the keyboard smaller if there are just two rows of buttons). Defaults to False, in which case the custom keyboard is always of the same height as the app's standard keyboard.
fn reply_keyboard_markup_has_resize_keyboard(value: ReplyKeyboardMarkup): bool {
  return json_has(value.json, "resize_keyboard")
}
fn reply_keyboard_markup_get_resize_keyboard(value: ReplyKeyboardMarkup): bool {
  return json_bool(json_get(value.json, "resize_keyboard"))
}

// Optional. Requests clients to hide the keyboard as soon as it's been used. The keyboard will still be available, but clients will automatically display the usual letter-keyboard in the chat - the user can press a special button in the input field to see the custom keyboard again. Defaults to False.
fn reply_keyboard_markup_has_one_time_keyboard(value: ReplyKeyboardMarkup): bool {
  return json_has(value.json, "one_time_keyboard")
}
fn reply_keyboard_markup_get_one_time_keyboard(value: ReplyKeyboardMarkup): bool {
  return json_bool(json_get(value.json, "one_time_keyboard"))
}

// Optional. The placeholder to be shown in the input field when the keyboard is active; 1-64 characters
fn reply_keyboard_markup_has_input_field_placeholder(value: ReplyKeyboardMarkup): bool {
  return json_has(value.json, "input_field_placeholder")
}
fn reply_keyboard_markup_get_input_field_placeholder(value: ReplyKeyboardMarkup): str {
  return json_string(json_get(value.json, "input_field_placeholder"))
}

// Optional. Use this parameter if you want to show the keyboard to specific users only. Targets: 1) users that are @mentioned in the text of the Message object; 2) if the bot's message is a reply to a message in the same chat and forum topic, sender of the original message.Example: A user requests to change the bot's language, bot replies to the request with a keyboard to select the new language. Other users in the group don't see the keyboard.
fn reply_keyboard_markup_has_selective(value: ReplyKeyboardMarkup): bool {
  return json_has(value.json, "selective")
}
fn reply_keyboard_markup_get_selective(value: ReplyKeyboardMarkup): bool {
  return json_bool(json_get(value.json, "selective"))
}

// Text of the button. If none of the fields other than text, icon_custom_emoji_id, and style are used, it will be sent as a message when the button is pressed.
fn keyboard_button_has_text(value: KeyboardButton): bool {
  return json_has(value.json, "text")
}
fn keyboard_button_get_text(value: KeyboardButton): str {
  return json_string(json_get(value.json, "text"))
}

// Optional. Unique identifier of the custom emoji shown before the text of the button. Can only be used by bots that purchased additional usernames on Fragment or in the messages directly sent by the bot to private, group and supergroup chats if the owner of the bot has a Telegram Premium subscription.
fn keyboard_button_has_icon_custom_emoji_id(value: KeyboardButton): bool {
  return json_has(value.json, "icon_custom_emoji_id")
}
fn keyboard_button_get_icon_custom_emoji_id(value: KeyboardButton): str {
  return json_string(json_get(value.json, "icon_custom_emoji_id"))
}

// Optional. Style of the button. Must be one of “danger” (red), “success” (green) or “primary” (blue). If omitted, then an app-specific style is used.
fn keyboard_button_has_style(value: KeyboardButton): bool {
  return json_has(value.json, "style")
}
fn keyboard_button_get_style(value: KeyboardButton): str {
  return json_string(json_get(value.json, "style"))
}

// Optional. If specified, pressing the button will open a list of suitable users. Identifiers of selected users will be sent to the bot in a “users_shared” service message. Available in private chats only.
fn keyboard_button_has_request_users(value: KeyboardButton): bool {
  return json_has(value.json, "request_users")
}
fn keyboard_button_get_request_users(value: KeyboardButton): KeyboardButtonRequestUsers {
  return KeyboardButtonRequestUsers { json: json_get(value.json, "request_users") }
}

// Optional. If specified, pressing the button will open a list of suitable chats. Tapping on a chat will send its identifier to the bot in a “chat_shared” service message. Available in private chats only.
fn keyboard_button_has_request_chat(value: KeyboardButton): bool {
  return json_has(value.json, "request_chat")
}
fn keyboard_button_get_request_chat(value: KeyboardButton): KeyboardButtonRequestChat {
  return KeyboardButtonRequestChat { json: json_get(value.json, "request_chat") }
}

// Optional. If specified, pressing the button will ask the user to create and share a bot that will be managed by the current bot. Available for bots that enabled management of other bots in the @BotFather Mini App. Available in private chats only.
fn keyboard_button_has_request_managed_bot(value: KeyboardButton): bool {
  return json_has(value.json, "request_managed_bot")
}
fn keyboard_button_get_request_managed_bot(value: KeyboardButton): KeyboardButtonRequestManagedBot {
  return KeyboardButtonRequestManagedBot { json: json_get(value.json, "request_managed_bot") }
}

// Optional. If True, the user's phone number will be sent as a contact when the button is pressed. Available in private chats only.
fn keyboard_button_has_request_contact(value: KeyboardButton): bool {
  return json_has(value.json, "request_contact")
}
fn keyboard_button_get_request_contact(value: KeyboardButton): bool {
  return json_bool(json_get(value.json, "request_contact"))
}

// Optional. If True, the user's current location will be sent when the button is pressed. Available in private chats only.
fn keyboard_button_has_request_location(value: KeyboardButton): bool {
  return json_has(value.json, "request_location")
}
fn keyboard_button_get_request_location(value: KeyboardButton): bool {
  return json_bool(json_get(value.json, "request_location"))
}

// Optional. If specified, the user will be asked to create a poll and send it to the bot when the button is pressed. Available in private chats only.
fn keyboard_button_has_request_poll(value: KeyboardButton): bool {
  return json_has(value.json, "request_poll")
}
fn keyboard_button_get_request_poll(value: KeyboardButton): KeyboardButtonPollType {
