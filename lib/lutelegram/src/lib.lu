// Optional. Identifier of the message that will be replied to in the current chat, or in the chat chat_id if it is specified. Required if ephemeral_message_id isn't specified.
fn reply_parameters_has_message_id(value: ReplyParameters): bool {
  return json_has(value.json, "message_id")
}
fn reply_parameters_get_message_id(value: ReplyParameters): i64 {
  return json_i64(json_get(value.json, "message_id"))
}

// Optional. If the message to be replied to is from a different chat, unique identifier for the chat or username of the bot, supergroup or channel in the format @username. Not supported for messages sent on behalf of a business account, messages from channel direct messages chats and ephemeral messages.
fn reply_parameters_has_chat_id(value: ReplyParameters): bool {
  return json_has(value.json, "chat_id")
}
fn reply_parameters_get_chat_id(value: ReplyParameters): str {
  return json_get(value.json, "chat_id")
}

// Optional. Identifier of the incoming ephemeral message that will be replied to in the current chat. A reply to an ephemeral message must itself be an ephemeral message. An ephemeral message may only be replied to within 15 seconds of being sent. Required if message_id isn't specified.
fn reply_parameters_has_ephemeral_message_id(value: ReplyParameters): bool {
  return json_has(value.json, "ephemeral_message_id")
}
fn reply_parameters_get_ephemeral_message_id(value: ReplyParameters): i64 {
  return json_i64(json_get(value.json, "ephemeral_message_id"))
}

// Optional. Pass True if the message should be sent even if the specified message to be replied to is not found. Always False for replies in another chat or forum topic, and sent ephemeral messages. Always True for messages sent on behalf of a business account.
fn reply_parameters_has_allow_sending_without_reply(value: ReplyParameters): bool {
  return json_has(value.json, "allow_sending_without_reply")
}
fn reply_parameters_get_allow_sending_without_reply(value: ReplyParameters): bool {
  return json_bool(json_get(value.json, "allow_sending_without_reply"))
}

// Optional. Quoted part of the message to be replied to; 0-1024 characters after entities parsing. The quote must be an exact substring of the message to be replied to, including bold, italic, underline, strikethrough, spoiler, custom_emoji, and date_time entities. The message will fail to send if the quote isn't found in the original message. Ignored for ephemeral messages.
fn reply_parameters_has_quote(value: ReplyParameters): bool {
  return json_has(value.json, "quote")
}
fn reply_parameters_get_quote(value: ReplyParameters): str {
  return json_string(json_get(value.json, "quote"))
}

// Optional. Mode for parsing entities in the quote. See formatting options for more details.
fn reply_parameters_has_quote_parse_mode(value: ReplyParameters): bool {
  return json_has(value.json, "quote_parse_mode")
}
fn reply_parameters_get_quote_parse_mode(value: ReplyParameters): str {
  return json_string(json_get(value.json, "quote_parse_mode"))
}

// Optional. A JSON-serialized list of special entities that appear in the quote. It can be specified instead of quote_parse_mode.
fn reply_parameters_has_quote_entities(value: ReplyParameters): bool {
  return json_has(value.json, "quote_entities")
}
fn reply_parameters_get_quote_entities(value: ReplyParameters): str {
  return json_get(value.json, "quote_entities")
}

// Optional. Position of the quote in the original message in UTF-16 code units
fn reply_parameters_has_quote_position(value: ReplyParameters): bool {
  return json_has(value.json, "quote_position")
}
fn reply_parameters_get_quote_position(value: ReplyParameters): i64 {
  return json_i64(json_get(value.json, "quote_position"))
}

